     factor *= 1.0 - q["thaw_penalty"] * max(0.0, min(1.0, thaw))
+    factor *= 1.0 - q["wind_penalty"] * max(0.0, min(1.0, wind_scour))
     return max(q["floor"], min(1.0, factor))
 
 
