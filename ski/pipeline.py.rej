+def decayed_new_snow_in(obs: pd.DataFrame, as_of: date | None = None,
+                        refreeze: float = 0.0) -> float | None:
+    """Age-decayed on-ground powder inches for the skiability headline (Phase 5).
+
+    Each day's new snow is weighted by 0.5 ** (age_days / half_life), summed over
+    the trailing POWDER_DECAY['max_age_days']. The half-life is POWDER_DECAY's cold
+    value when the pack is undisturbed and shortens toward `min_half_life_days` as
+    the recent melt-freeze (`refreeze`, 0..1) rises -- so cold powder lingers and
+    thawed powder fades fast. Continuous, so there is no hard 7-day cliff: a storm
+    eight days ago still counts, just less than the same storm yesterday.
+
+    None when the window has no usable new-snow observations (same convention as
+    fresh_snow_total)."""
+    if obs is None or obs.empty:
+        return None
+    as_of = as_of or date.today()
+    end = pd.Timestamp(as_of)
+    p = POWDER_DECAY
+    start = end - pd.Timedelta(days=p["max_age_days"] - 1)
+    win = obs[(obs["date"] >= start) & (obs["date"] <= end)][["date", "new_snow_24hr"]]
+    if win["new_snow_24hr"].notna().sum() == 0:
+        return None
+    melt = max(0.0, min(1.0, refreeze))
+    half_life = max(p["min_half_life_days"], p["half_life_days_cold"] / (1.0 + p["melt_accel"] * melt))
+    age_days = (end - win["date"]).dt.days.clip(lower=0)
+    weights = 0.5 ** (age_days / half_life)
+    contrib = win["new_snow_24hr"].clip(lower=0).fillna(0.0) * weights
+    return float(contrib.sum())
+
+
+def buried_crust_index(obs: pd.DataFrame, as_of: date | None = None) -> float | None:
+    """Severity 0 (none) .. 1 (firm buried ice) of a persisting rain/melt crust,
+    from the stored pillow record (Phase 5b). SNOTEL + Mammoth only.
+
+    A rain-on-snow or strong melt pulse adds WATER without HEIGHT: a day whose SWE
+    jumps by >= CRUST_MEMORY['rain_swe_in'] while depth rises no more than
+    'depth_flat_in' is such a pulse (a snowfall would raise both). Each pulse's
+    severity (from the SWE jump) then fades as new snow buries it -- 'bury_full_in'
+    inches since the pulse largely erases it. The worst still-relevant crust wins.
+
+    Returns None when the station lacks a usable SWE+depth pair in the window (not
+    a pillow station) -- unknown, not zero, so those mountains fall back to the
+    trailing refreeze signal. 0.0 when it IS a pillow station with no live crust."""
+    if obs is None or obs.empty:
+        return None
+    as_of = as_of or date.today()
+    c = CRUST_MEMORY
+    end = pd.Timestamp(as_of)
+    start = end - pd.Timedelta(days=c["lookback_days"] - 1)
+    win = obs[(obs["date"] >= start) & (obs["date"] <= end)].sort_values("date")
+    if win["swe_inches"].notna().sum() < 2 or win["snow_depth_inches"].notna().sum() < 2:
+        return None                    # not a SWE+depth (pillow) station
+    dswe = win["swe_inches"].diff()
+    ddepth = win["snow_depth_inches"].diff()
+    worst = 0.0
+    for i, (_, row) in enumerate(win.iterrows()):
+        ds, dd = dswe.iloc[i], ddepth.iloc[i]
+        if pd.isna(ds) or pd.isna(dd):
+            continue
+        if ds >= c["rain_swe_in"] and dd <= c["depth_flat_in"]:
+            severity = _ramp_local(ds, c["rain_swe_in"], c["rain_swe_full_in"])
+            snow_since = win[win["date"] > row["date"]]["new_snow_24hr"].clip(lower=0).sum(skipna=True)
+            burial = 1.0 - _ramp_local(float(snow_since), c["bury_zero_in"], c["bury_full_in"])
+            worst = max(worst, severity * burial)
+    return float(worst)
+
+
+def _ramp_local(x: float, lo: float, hi: float) -> float:
+    """0 at/below lo, 1 at/above hi, linear between (mirrors score._ramp; kept here
+    so pipeline helpers don't reach into score for a two-line utility)."""
+    if hi <= lo:
+        return 1.0 if x >= hi else 0.0
+    return min(1.0, max(0.0, (x - lo) / (hi - lo)))
+
+
+def measured_new_snow_density(obs: pd.DataFrame, as_of: date | None = None,
+                              window_days: int = COMPARABLE_FRESH_WINDOW_DAYS) -> float | None:
+    """New-snow water fraction (SWE gain / depth gain) over the trailing window --
+    the Tier-1 (measured) density signal for stations with BOTH SWE and depth
+    (the 36 SNOTEL + Mammoth; verified 2026-07-17).
+
+    Depth gain is the trailing new-snow total; water gain is the sum of positive
+    day-over-day SWE changes in the window (settling/melt days, which are negative,
+    don't count as new water). Returns None when either channel is missing or the
+    accumulation is below DENSITY_MIN_SNOW_IN -- too little to tell light from
+    heavy, so the caller falls back to the Tier-2 temperature estimate. Clamped to
+    a physically plausible band so a data glitch can't emit an absurd ratio."""
+    if obs is None or obs.empty:
+        return None
+    as_of = as_of or date.today()
+    end = pd.Timestamp(as_of)
+    start = end - pd.Timedelta(days=window_days - 1)
+    win = obs[(obs["date"] >= start) & (obs["date"] <= end)]
+    if win.empty or win["swe_inches"].notna().sum() == 0:
+        return None            # no SWE channel -> not a measured-density station
+    depth_gain = win["new_snow_24hr"].sum(skipna=True) if win["new_snow_24hr"].notna().any() else 0.0
+    if depth_gain < DENSITY_MIN_SNOW_IN:
+        return None
+    # Water gain: positive SWE steps within the window, including the step from the
+    # last reading just before it (so a storm that began on `start` isn't clipped).
+    prior = obs[obs["date"] < start]["swe_inches"].dropna()
+    swe_series = win["swe_inches"].dropna()
+    if not prior.empty:
+        swe_series = pd.concat([prior.iloc[[-1]], swe_series])
+    water_gain = float(swe_series.diff().clip(lower=0).sum(skipna=True))
+    if water_gain <= 0.0:
+        return None
+    # float(): depth_gain is a numpy scalar from pandas .sum(); keep the ratio a
+    # plain Python float so it stays JSON-serializable through the card and the
+    # snow-quality component breakdown.
+    return float(max(0.02, min(0.40, water_gain / float(depth_gain))))
+
+
 def season_snow_equivalent_in(season: SeasonGrade) -> float | None:
     """Season-to-date total in a common SNOW-inches unit, for ski.comparable.
 
