# Runtime data
data/*.db
data/*.sqlite

# Generated static snapshot (today's scores/cards/meta -- rebuilt every run).
web/data/*
# ...but KEEP the retrospective history: it's immutable + incremental (built once
# per date, then persisted so the daily build only appends new dates).
!web/data/hist/

